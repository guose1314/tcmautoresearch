# src/learning/self_learning_engine.py
"""
自我学习引擎 - 增强集成版本

新增能力：
- 指数加权移动平均（EWMA）性能评分，近期结果权重更高
- 集成 PatternRecognizer：实时识别数据处理模式
- 集成 AdaptiveTuner：根据性能趋势自动调节运行参数
- learn_from_feedback() API：接受外部反馈并修正历史记录权重
- 多维性能评估：实体密度 + 置信度 + 语义图完整性 + 推理质量
"""
import pickle
import hashlib
from typing import Dict, List, Any, Optional
from datetime import datetime
import logging
from src.core.module_base import BaseModule

logger = logging.getLogger(__name__)

class LearningRecord:
    """学习记录"""
    
    def __init__(self, task_id: str, input_data: Dict[str, Any], 
                 output_data: Dict[str, Any], performance: float, 
                 timestamp: str = None):
        self.task_id = task_id
        self.input_data = input_data
        self.output_data = output_data
        self.performance = performance  # 0-1之间的性能评分
        self.timestamp = timestamp or datetime.now().isoformat()
        self.feedback = None  # 用户反馈
        
    def to_dict(self) -> Dict[str, Any]:
        """转换为字典"""
        return {
            "task_id": self.task_id,
            "input_data": self.input_data,
            "output_data": self.output_data,
            "performance": self.performance,
            "timestamp": self.timestamp,
            "feedback": self.feedback
        }
    
    @classmethod
    def from_dict(cls, data: Dict[str, Any]) -> 'LearningRecord':
        """从字典创建对象"""
        record = cls(
            task_id=data["task_id"],
            input_data=data["input_data"],
            output_data=data["output_data"],
            performance=data["performance"],
            timestamp=data["timestamp"]
        )
        record.feedback = data.get("feedback")
        return record

class SelfLearningEngine(BaseModule):
    """
    自我学习引擎 - 增强集成版本。

    额外功能
    --------
    - EWMA 加权性能历史（可通过 ewma_alpha 配置衰减率）
    - 内嵌 PatternRecognizer 实时模式挖掘
    - 内嵌 AdaptiveTuner 自动参数调节
    - learn_from_feedback() 支持外部评分修正
    """

    _EWMA_DEFAULT_ALPHA = 0.15   # 默认平滑系数（值越小越重视历史）

    def __init__(self, config: Dict[str, Any] = None):
        super().__init__("self_learning_engine", config)
        self.learning_records: List[LearningRecord] = []
        self.performance_history: List[float] = []
        self.model_improvement_log: List[Dict[str, Any]] = []
        self.learning_threshold = self.config.get("learning_threshold", 0.7)
        self.min_performance_for_improvement = self.config.get(
            "min_performance_for_improvement", 0.8
        )
        self._ewma_alpha = float(self.config.get("ewma_alpha", self._EWMA_DEFAULT_ALPHA))
        self._ewma_score: Optional[float] = None   # 当前 EWMA 性能估计

        # 延迟初始化子模块（避免导入副作用）
        self._pattern_recognizer = None
        self._adaptive_tuner = None
        
    def _do_initialize(self) -> bool:
        """初始化学习引擎。"""
        try:
            self._load_learning_data()
            # 初始化子模块
            self._init_submodules()
            self.logger.info("自我学习引擎初始化成功")
            return True
        except Exception as e:
            self.logger.error(f"自我学习引擎初始化失败: {e}")
            return False

    def _init_submodules(self) -> None:
        """按需初始化模式识别器和自适应调整器。"""
        try:
            from src.learning.pattern_recognizer import PatternRecognizer
            self._pattern_recognizer = PatternRecognizer(
                min_frequency=self.config.get("pattern_min_frequency", 2),
                anomaly_z_threshold=self.config.get("anomaly_z_threshold", 2.5),
            )
        except ImportError:
            self.logger.warning("PatternRecognizer 不可用，跳过模式识别初始化")

        try:
            from src.learning.adaptive_tuner import AdaptiveTuner
            self._adaptive_tuner = AdaptiveTuner(
                performance_target=self.config.get("performance_target", 0.80),
            )
        except ImportError:
            self.logger.warning("AdaptiveTuner 不可用，跳过自适应调整器初始化")
    
    def _do_execute(self, context: Dict[str, Any]) -> Dict[str, Any]:
        """执行学习逻辑，含模式识别与自适应调参。"""
        try:
            # 1. 记录本轮数据，更新 EWMA
            self._record_learning_data(context)

            # 2. 评估并生成改进建议
            improvement_suggestion = self._evaluate_and_improve(context)

            # 3. 模式识别
            discovered_patterns: List[Dict[str, Any]] = []
            if self._pattern_recognizer is not None:
                try:
                    patterns = self._pattern_recognizer.analyze(context)
                    discovered_patterns = [p.to_dict() for p in patterns]
                except Exception as exc:
                    self.logger.warning(f"模式识别执行失败: {exc}")

            # 4. 自适应调参
            tuned_params: Dict[str, float] = {}
            if self._adaptive_tuner is not None and self._ewma_score is not None:
                try:
                    tuned_params = self._adaptive_tuner.step({
                        "performance": self._ewma_score,
                        "quality": context.get("quality_score", self._ewma_score),
                        "confidence": context.get("confidence_score", 0.5),
                    })
                    # 同步调参结果到本引擎阈值
                    if "learning_threshold" in tuned_params:
                        self.learning_threshold = tuned_params["learning_threshold"]
                    if "min_performance_for_improvement" in tuned_params:
                        self.min_performance_for_improvement = tuned_params.get(
                            "quality_threshold", self.min_performance_for_improvement
                        )
                except Exception as exc:
                    self.logger.warning(f"自适应调参执行失败: {exc}")

            output_data: Dict[str, Any] = {
                "learning_suggestions": improvement_suggestion,
                "discovered_patterns": discovered_patterns,
                "tuned_parameters": tuned_params,
                "ewma_performance": round(self._ewma_score, 4) if self._ewma_score is not None else None,
                "learning_timestamp": datetime.now().isoformat(),
            }
            return output_data

        except Exception as e:
            self.logger.error(f"自我学习执行失败: {e}")
            raise
    
    def _record_learning_data(self, context: Dict[str, Any]) -> None:
        """记录学习数据并更新 EWMA。"""
        try:
            task_id = self._generate_task_id(context)
            input_data = {
                "text": context.get("processed_text", "")[:200],
                "metadata": context.get("metadata", {}),
            }
            output_data = {
                "entities": context.get("entities", {}),
                "semantic_graph": context.get("semantic_graph", {}),
                "reasoning_results": context.get("reasoning_results", {}),
            }
            performance = self._calculate_performance(context)

            # 更新 EWMA
            if self._ewma_score is None:
                self._ewma_score = performance
            else:
                self._ewma_score = (
                    self._ewma_alpha * performance
                    + (1 - self._ewma_alpha) * self._ewma_score
                )

            record = LearningRecord(
                task_id=task_id,
                input_data=input_data,
                output_data=output_data,
                performance=performance,
            )
            self.learning_records.append(record)
            self.performance_history.append(performance)
            # 防止无限增长
            if len(self.learning_records) > 2000:
                self.learning_records.pop(0)
            if len(self.performance_history) > 2000:
                self.performance_history.pop(0)

            self._save_learning_data()
            self.logger.debug(f"学习记录已保存，任务ID: {task_id}")

        except Exception as e:
            self.logger.error(f"学习数据记录失败: {e}")
                input_data=input_data,
                output_data=output_data,
                performance=performance
            )
            
            # 保存记录
            self.learning_records.append(record)
            self.performance_history.append(performance)
            
            # 保存到文件
            self._save_learning_data()
            
            self.logger.info(f"学习记录已保存，任务ID: {task_id}")
            
        except Exception as e:
            self.logger.error(f"学习数据记录失败: {e}")
    
    def _generate_task_id(self, context: Dict[str, Any]) -> str:
        """生成任务ID"""
        text_content = context.get("processed_text", "")[:100]  # 截取前100字符
        metadata = str(context.get("metadata", {}))
        combined = text_content + metadata
        return hashlib.md5(combined.encode()).hexdigest()[:16]
    
    def _calculate_performance(self, context: Dict[str, Any]) -> float:
        """计算性能评分"""
        # 这里可以根据多个维度计算性能
        entities = context.get("entities", [])
        confidence = context.get("confidence_score", 0.5)
        
        # 简单的性能计算逻辑
        performance = min((confidence + len(entities) * 0.05) / 2, 1.0)
        return performance
    
    def _evaluate_and_improve(self, context: Dict[str, Any]) -> List[Dict[str, Any]]:
        """评估并提出改进建议"""
        suggestions = []
        
        # 检查最近性能趋势
        if len(self.performance_history) >= 10:
            recent_performance = self.performance_history[-10:]
            avg_performance = sum(recent_performance) / len(recent_performance)
            
            # 如果性能下降，提出改进建议
            if avg_performance < self.learning_threshold:
                suggestion = {
                    "type": "performance_degradation",
                    "message": "检测到近期性能下降，建议调整模型参数或增加训练数据",
                    "timestamp": datetime.now().isoformat()
                }
                suggestions.append(suggestion)
            
            # 如果性能良好，但有改进空间
            if avg_performance > self.min_performance_for_improvement:
                suggestion = {
                    "type": "optimization_opportunity",
                    "message": "当前性能良好，建议进一步优化以提升准确性",
                    "timestamp": datetime.now().isoformat()
                }
                suggestions.append(suggestion)
        
        # 检查是否有特定的错误模式
        error_patterns = self._detect_error_patterns(context)
        if error_patterns:
            suggestions.extend(error_patterns)
        
        return suggestions
    
    def _detect_error_patterns(self, context: Dict[str, Any]) -> List[Dict[str, Any]]:
        """检测错误模式"""
        patterns = []
        
        # 检查实体识别遗漏
        entities = context.get("entities", [])
        if len(entities) < 2:  # 实体太少可能是遗漏
            pattern = {
                "type": "low_entity_recognition",
                "message": "实体识别数量较少，可能存在漏检情况",
                "suggestion": "增加训练样本或调整识别参数",
                "timestamp": datetime.now().isoformat()
            }
            patterns.append(pattern)
        
        return patterns
    
    def _save_learning_data(self):
        """保存学习数据"""
        try:
            # 保存到文件
            with open(self.config.get("learning_data_file", "learning_data.pkl"), "wb") as f:
                pickle.dump({
                    "records": [record.to_dict() for record in self.learning_records],
                    "performance_history": self.performance_history,
                    "model_improvement_log": self.model_improvement_log
                }, f)
                
        except Exception as e:
            self.logger.error(f"保存学习数据失败: {e}")
    
    def _load_learning_data(self):
        """加载学习数据"""
        try:
            file_path = self.config.get("learning_data_file", "learning_data.pkl")
            with open(file_path, "rb") as f:
                data = pickle.load(f)
                
            # 加载记录
            self.learning_records = [
                LearningRecord.from_dict(record_data) 
                for record_data in data["records"]
            ]
            
            # 加载性能历史
            self.performance_history = data["performance_history"]
            
            # 加载改进日志
            self.model_improvement_log = data.get("model_improvement_log", [])
            
            self.logger.info(f"加载了 {len(self.learning_records)} 条学习记录")
            
        except FileNotFoundError:
            self.logger.info("未找到学习数据文件，将创建新的学习记录")
        except Exception as e:
            self.logger.error(f"加载学习数据失败: {e}")
    
    def _do_cleanup(self) -> bool:
        """清理资源"""
        try:
            self._save_learning_data()
            self.logger.info("自我学习引擎资源清理完成")
            return True
        except Exception as e:
            self.logger.error(f"自我学习引擎资源清理失败: {e}")
            return False
    
    def get_learning_stats(self) -> Dict[str, Any]:
        """获取学习统计信息"""
        if not self.performance_history:
            return {}
        
        return {
            "total_records": len(self.learning_records),
            "average_performance": sum(self.performance_history) / len(self.performance_history),
            "recent_performance": self.performance_history[-10:],
            "model_improvement_log": self.model_improvement_log
        }
